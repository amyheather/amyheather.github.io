```{=html}
<div class="pub-list">

<%
  // Detect grouped vs flat
  const grouped =
    items.length > 0 &&
    items[0].tiles &&
    Array.isArray(items[0].tiles);

  // Reusable renderer for a single tile
    function renderTile(tile) { %>

    <div class="box paper" <%= metadataAttrs(tile) %>>

      <div class="paper-main">
        <div class="listing-title">
          <%- tile.title %>
        </div>

        <% if (tile.authors) { %>
          <div class="listing-authors">
            <%= tile.authors %>
          </div>
        <% } %>

        <% if (tile.journal || tile.date) { %>
          <em class="listing-journal">
            <% if (tile.journal) { %><%- tile.journal %><% } %>
            <% if (tile.journal && tile.date) { %> ˖ <% } %>
            <% if (tile.date) { %><span class="listing-date"><%- tile.date %></span><% } %>
          </em>
        <% } %>

        <div class="paper-buttons">
          <% if (tile.doi) { %>
            <a href="<%- tile.doi %>" class="btn-pub" target="_blank" rel="noopener">DOI</a>
          <% } %>
          <% if (tile['preprint']) { %>
            <a href="<%- tile['preprint'] %>" class="btn-pub" target="_blank" rel="noopener">Preprint</a>
          <% } %>
          <% if (tile['pdf']) { %>
            <a href="<%- tile['pdf'] %>" class="btn-pub" target="_blank" rel="noopener">PDF</a>
          <% } %>
          <% if (tile['github']) { %>
            <a href="<%- tile['github'] %>" class="btn-pub" target="_blank" rel="noopener">GitHub</a>
          <% } %>
        </div>
      </div>

    </div>

<% } // end renderTile %>

<% if (grouped) { %>

  <% for (const item of items) { %>

    <% if (item.category) { %>
      <h2><%- item.category %></h2>
    <% } %>

    <div class="pub-list list">
      <% for (const tile of item.tiles) { %>
        <% renderTile(tile); %>
      <% } %>
    </div>

  <% } %>

<% } else { %>

  <div class="pub-list list">
    <% for (const tile of items) { %>
      <% renderTile(tile); %>
    <% } %>
  </div>

<% } %>

</div>
```